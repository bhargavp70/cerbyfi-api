{
  "categories": {
    "business_quality": {
      "label": "Business Quality",
      "max_score": 30,
      "metrics": {
        "revenue_growth": {
          "label": "Revenue Growth (YoY)",
          "max_score": 10,
          "source": "auto",
          "field": "revenue_growth_yoy",
          "direction": "min",
          "format": "percent",
          "note": "Thresholds in decimals: 0.15 = 15% growth",
          "thresholds": [
            {"value": 0.15, "score": 10},
            {"value": 0.08, "score": 7},
            {"value": 0.03, "score": 5},
            {"value": -999, "score": 2}
          ]
        },
        "profitability": {
          "label": "Profitability (Operating Margin)",
          "max_score": 10,
          "source": "auto",
          "field": "operatingMargins",
          "direction": "min",
          "format": "percent",
          "note": "Thresholds in decimals: 0.20 = 20% margin",
          "thresholds": [
            {"value": 0.20, "score": 10},
            {"value": 0.12, "score": 7},
            {"value": 0.05, "score": 5},
            {"value": -999, "score": 2}
          ]
        },
        "moat": {
          "label": "Moat / Competitive Advantage",
          "max_score": 10,
          "source": "auto",
          "field": "moat_proxy",
          "direction": "min",
          "format": "percent",
          "note": "Proxy: avg of gross margin + ROE (normalized). 0.5 = 50% combined score.",
          "thresholds": [
            {"value": 0.50, "score": 10},
            {"value": 0.30, "score": 7},
            {"value": 0.10, "score": 3},
            {"value": -999, "score": 1}
          ]
        }
      }
    },
    "financial_strength": {
      "label": "Financial Strength",
      "max_score": 20,
      "metrics": {
        "debt_level": {
          "label": "Debt Level (Debt/Equity)",
          "max_score": 10,
          "source": "auto",
          "field": "debtToEquity",
          "direction": "max",
          "format": "number",
          "note": "100 = 1.0x D/E ratio. Lower is better.",
          "thresholds": [
            {"value": 30,     "score": 10},
            {"value": 80,     "score": 7},
            {"value": 150,    "score": 5},
            {"value": 999999, "score": 2}
          ]
        },
        "cash_flow": {
          "label": "Cash Flow Quality (FCF Margin)",
          "max_score": 10,
          "source": "auto",
          "field": "fcf_margin",
          "direction": "min",
          "format": "percent",
          "note": "Thresholds in decimals: 0.15 = 15% FCF margin",
          "thresholds": [
            {"value": 0.15, "score": 10},
            {"value": 0.08, "score": 7},
            {"value": 0.03, "score": 5},
            {"value": -999, "score": 2}
          ]
        }
      }
    },
    "growth_potential": {
      "label": "Growth Potential",
      "max_score": 20,
      "metrics": {
        "eps_growth": {
          "label": "EPS Growth (YoY)",
          "max_score": 10,
          "source": "auto",
          "field": "eps_growth",
          "direction": "min",
          "format": "percent",
          "note": "Year-over-year EPS growth. 0.20 = 20%.",
          "thresholds": [
            {"value": 0.20, "score": 10},
            {"value": 0.10, "score": 7},
            {"value": 0.00, "score": 4},
            {"value": -999, "score": 2}
          ]
        },
        "revenue_growth_5y": {
          "label": "Revenue Growth (5-Year CAGR)",
          "max_score": 10,
          "source": "auto",
          "field": "revenue_growth_5y",
          "direction": "min",
          "format": "percent",
          "note": "5-year annualised revenue growth (CAGR). 0.15 = 15% per year.",
          "thresholds": [
            {"value": 0.15, "score": 10},
            {"value": 0.08, "score": 7},
            {"value": 0.02, "score": 4},
            {"value": -999, "score": 2}
          ]
        }
      }
    },
    "valuation": {
      "label": "Valuation",
      "max_score": 20,
      "metrics": {
        "relative_valuation": {
          "label": "Relative Valuation (P/E Ratio)",
          "max_score": 10,
          "source": "auto",
          "field": "trailingPE",
          "direction": "max",
          "format": "number",
          "note": "Lower P/E = better value",
          "thresholds": [
            {"value": 15,     "score": 10},
            {"value": 25,     "score": 7},
            {"value": 40,     "score": 5},
            {"value": 999999, "score": 2}
          ]
        },
        "price_to_fcf": {
          "label": "Price / Free Cash Flow",
          "max_score": 10,
          "source": "auto",
          "field": "price_to_fcf",
          "direction": "max",
          "format": "number",
          "note": "Lower P/FCF = better value. < 20 is attractive.",
          "thresholds": [
            {"value": 20,     "score": 10},
            {"value": 30,     "score": 7},
            {"value": 50,     "score": 4},
            {"value": 999999, "score": 2}
          ]
        }
      }
    },
    "management": {
      "label": "Management & Governance",
      "max_score": 10,
      "metrics": {
        "capital_allocation": {
          "label": "Capital Allocation (ROE)",
          "max_score": 5,
          "source": "auto",
          "field": "capital_allocation_proxy",
          "direction": "min",
          "format": "percent",
          "note": "Proxy: Return on Equity. 0.20 = 20% ROE.",
          "thresholds": [
            {"value": 0.20, "score": 5},
            {"value": 0.10, "score": 3},
            {"value": -999, "score": 1}
          ]
        },
        "roic": {
          "label": "Return on Invested Capital (ROIC)",
          "max_score": 5,
          "source": "auto",
          "field": "roic",
          "direction": "min",
          "format": "percent",
          "note": "ROIC measures how efficiently management deploys capital. 0.20 = 20%.",
          "thresholds": [
            {"value": 0.20, "score": 5},
            {"value": 0.10, "score": 3},
            {"value": -999, "score": 1}
          ]
        }
      }
    }
  }
}
